{
  "builds": [
    {
      "src": "webapp/app.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": [
          "webapp/templates/**",
          "webapp/static/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "webapp/app.py"
    }
  ]
}
